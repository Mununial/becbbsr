<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Bypass rewriting for API requests
  # This allows the Express server (if running via Node.js hosting or Passenger) to process /api routes
  RewriteCond %{REQUEST_URI} ^/api [NC]
  RewriteRule ^(.*)$ - [L]

  # 2. Rewrite root traffic to the React built files in client/dist/
  # If a file exists under client/dist/, rewrite to it
  RewriteCond %{DOCUMENT_ROOT}/client/dist%{REQUEST_URI} -f
  RewriteRule ^(.*)$ /client/dist/$1 [L]

  # If a directory exists under client/dist/, rewrite to it
  RewriteCond %{DOCUMENT_ROOT}/client/dist%{REQUEST_URI} -d
  RewriteRule ^(.*)$ /client/dist/$1 [L]

  # 3. SPA Routing Fallback: Rewrite all other requests to client/dist/index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /client/dist/index.html [L]
</IfModule>
