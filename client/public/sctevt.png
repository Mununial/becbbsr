        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        function downloadTableAsCSV(d) {
            // var table = document.getElementById("data-table");
            debugger;
            var table = $(d).closest('.modal-content').find('.table')[0];
            var rows = table.querySelectorAll("tr");
            var csv = [];

            rows.forEach(function(row) {
                var cells = row.querySelectorAll("th, td");
                var rowData = Array.from(cells).map(function(cell) {
                    return '"' + cell.innerText.replace(/"/g, '""') + '"'; // Escape double quotes in CSV
                });
                csv.push(rowData.join(","));
            });

            var csvString = csv.join("\n");
            var blob = new Blob([csvString], {
                type: 'text/csv'
            });
            var url = URL.createObjectURL(blob);
            var a = document.createElement("a");
            a.setAttribute("hidden", "");
            a.setAttribute("href", url);
            a.setAttribute("download", "Institution_List.csv");
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }


        var academicYearId = null; // Global variable to store academic year ID

        function getAcademicyear(id, course_id, institution_type_id = "") {
            // alert(course_id);
            // debugger
            $.ajax({
                type: "POST",
                dataType: "json",
                url: "https://sctevt.odisha.gov.in/dashboard/ajax/getAcademicyear",
                data: {
                    'course_id': course_id,
                    'institution_type_id': institution_type_id,
                    "academic_year_id": id,
                    "_token": "yXRKD9HRd1lecDt3RfEFv6Jf8Th9SgNKCuWeS1rl"
                },
                success: function(data) {
                    if (data.response == 1) {
                        academicYearId = data.academic_year_id; // Store the academic year ID


                        var len = data.res.length;
                        var htmlData = '';

                        for (var i = 0; i < len; i++) {

                            if (data.res[i].data_source == 3) {
                                // alert(345);
                                var countlabelName = data.res[i].count_label_name;
                                var icon = data.res[i].icon;
                                $.ajax({

                                    type: "POST",
                                    dataType: "json",
                                    url: "https://sctevt.odisha.gov.in/dashboard/ajax/getcpcdata",
                                    data: {
                                        'institution_type_id': data.res[i].institution_type_id,
                                        'academic_year_id': data.res[i].academic_year_id,
                                        "course_id": data.res[i].course_id,
                                        "_token": "yXRKD9HRd1lecDt3RfEFv6Jf8Th9SgNKCuWeS1rl"
                                    },
                                    success: function(data) {
                                        var link = '';
                                        var studentcount = data.res.studentcount;
                                        var course = data.res.course;
                                        var academicyear = data.res.academicyear;
                                        var institutions = data.res.institutions;
                                        link =
                                            "https://sctevt.odisha.gov.in/en/dcount/student-placed?course=" +
                                            course + "&vacancy_for=" + institutions + "&fyear=" +
                                            academicyear;
                                        htmlData += '<div class="col-lg-4 col-sm-6">' +
                                            '<div class="single-counter">' +
                                            '<div class="counter-img">' +
                                            '<i class="' + icon + '"></i>' +
                                            // Dynamically set icon class
                                            '</div>' +
                                            '<div class="counter-content">' +
                                            '<span class="counter"><a href="' + link +
                                            '" target="_blank">' + studentcount + '</a></span>' +
                                            '<p>' + countlabelName + '</p>' +
                                            '</div>' +
                                            '</div>' +
                                            '</div>';

                                        $('.yr-wise-tabs > .row').html(htmlData);

                                        //var ittPrivateplacedCountDetail = response;
                                        //  alert(ittPrivateplacedCountDetail);
                                        // Construct HTML with the response data

                                    },
                                    error: function(xhr, status, error) {
                                        console.error("AJAX error:", status, error);
                                    }
                                });
                            } else {
                                var sitecode = 1;
                                var link = '';
                                var targetVal = "";
                                var getlang = 'en' ;
                                if (data.res[i].data_from == 1) {
                                    if (data.res[i].excel_upload != '') {
                                        if (data.res[i].posted_from == sitecode) {
                                            var link = 'https://sctevt.odisha.gov.in/show-excel-data/' + data.res[i]
                                                .excel_upload + '?title=' + data.res[i].count_label_name;
                                        } else {
                                            var msiteUrl = "";
                                            if (data.res[i].posted_from == 2) {
                                                msiteUrl = "https://dtet.odisha.gov.in/show-excel-data/" + data
                                                    .res[i].excel_upload;
                                            }
                                            if (data.res[i].posted_from == 3) {
                                                msiteUrl = "https://cpcdtet.odisha.gov.in/show-excel-data/" + data
                                                    .res[i].excel_upload;
                                            }
                                            if (data.res[i].posted_from == 4) {
                                                msiteUrl = "https://dsde.odisha.gov.in/show-excel-data/" + data
                                                    .res[i].excel_upload;
                                            }
                                            //var linkdata = 'https://sctevt.odisha.gov.in/show-excel-data/' + data.res[i].excel_upload;
                                            /*var link = 'https://sctevt.odisha.gov.in/share-excel-data/?excelfile=' +
                                                msiteUrl + '&title=' + data.res[i].count_label_name;*/
                                              var link = msiteUrl + '?title=' + data.res[i].count_label_name;
                                        }
                                        var targetVal = ' target="_blank"';
                                    } else {
                                        var link = 'javascript:void(0)';
                                    }
                                } else if (data.res[i].data_from == 2) {
                                    link = data.res[i].link;
                                    var targetVal = ' target="_blank"';
                                }

                                var labellangText;
                                if (getlang == 'od') {
                                    //alert(lang);
                                    labellangText = data.res[i].od_count_label_name;
                                    // You can uncomment the alert if needed
                                     //alert(lang);
                                } else {
                                    labellangText = data.res[i].count_label_name;
                                    // You can uncomment the alert if needed
                                    // alert(2);
                                }

                                var countlangText;
                                if (getlang == 'od') {
                                    //alert(lang);
                                    countlangText = data.res[
                                        i].od_count_data;
                                    // You can uncomment the alert if needed
                                     //alert(lang);
                                } else {
                                    countlangText = data.res[
                                        i].count_data;
                                    // You can uncomment the alert if needed
                                    // alert(2);
                                }

                                htmlData += '<div class="col-lg-4 col-sm-6">' +
                                    '<div class="single-counter">' +
                                    '<div class="counter-img">' +
                                    '<i class="' + data.res[i].icon + '"></i>' + // Dynamically set icon class
                                    '</div>' +
                                    '<div class="counter-content">' +
                                    '<span class="counter"><a href="' + link + '"' + targetVal + '>' + countlangText + '</a></span>' +
                                    '<p>' + labellangText + '</p>' +
                                    '</div>' +
                                    '</div>' +
                                    '</div>';
                            }
                        }
                        $('.yr-wise-tabs > .row').html(
                        htmlData); // Replace content of '.row' with generated HTML
                    } else {
                        console.log('No data available');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('AJAX Error: ' + status + ' - ' + error);
                }
            });
        }

        function getAcademicyearWise(id) {
            //alert(id);
            // debugger
            $("#appendDashboardData").html('<h4 class="text-center text-success">Loading...</h4>')
            $.ajax({
                type: "POST",
                dataType: "json",
                url: "https://sctevt.odisha.gov.in/ajax/getdatabyAcademicyear",
                data: {
                    "academic_year_id": id,
                    "_token": "yXRKD9HRd1lecDt3RfEFv6Jf8Th9SgNKCuWeS1rl"
                },
                success: function(data) {
                    //alert(data);
                    if (data.response == 1) {

                        $("#appendDashboardData").html(data.res);
                    } else {
                        console.log('No data available');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('AJAX Error: ' + status + ' - ' + error);
                }
            });
        }

        setTimeout(function() {
            getAcademicyear(document.getElementById('academic_year_id').value, 2, 2);
            //alert($("#academic_year_id").val())
            // getAcademicyearWise($("#academic_year_id").val());
        }, 300)

        window.onload = function() {
            setTimeout(function() {
                let twitterLink = null;
                let youtubeLink = null;
                

                $(".social-column").append(
                     ' <div class="col-md-6"><div class="card"> <h5 class="card-header d-flex justify-content-between"> <span>Twitter</span></h5> <div class="card-body" style="height: 403px; overflow: auto;"> <a class="twitter-timeline" href="https://twitter.com/SDTEOdisha?s=08">Tweets by SCTEVT</a>   </div></div> </div><div class="col-md-6"><div class="card"> <h5 class="card-header d-flex justify-content-between">  <span>Youtube</span> </h5> <div class="card-body"> <iframe width="100%" height="366" src="https://www.youtube.com/embed/QIvREiVaKXk?si=xWsMStzsKrMMN6wI" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>  </div> </div> </div>'
                     );


                var script = document.createElement('script');
                script.src = 'https://connect.facebook.net/en_GB/sdk.js#xfbml=1&version=v19.0';
                script.async = '';
                script.defer = '';
                script.nonce = 'DBE7I0NE';
                script.crossorigin = 'anonymous';
                document.body.appendChild(script);
                var twitterscript = document.createElement('script');
                twitterscript.src = 'https://platform.twitter.com/widgets.js';
                twitterscript.async = '';
                twitterscript.charset = 'utf-8';
                document.body.appendChild(twitterscript);
            }, 1000); // Delay of 5 seconds
        };
    </script>
    <style type="text/css">
        .news-ticker {
            height: 250px;
