              <path d="M 87.62 8.443 H 36.291 c -1.315 0 -2.38 1.066 -2.38 2.38 v 16.165 h 19.798 c 4.621 0 8.38 3.759 8.38 8.38 v 12.399 h 7.214 l 12.004 11.781 V 47.768 h 6.313 c 1.315 0 2.38 -1.066 2.38 -2.38 V 10.823 C 90 9.509 88.934 8.443 87.62 8.443 z M 78.845 32.452 H 67.623 v -3 h 11.222 V 32.452 z M 78.845 22.452 H 45.066 v -3 h 33.779 V 22.452 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round" />
              <path d="M 53.537 32.988 H 2.208 c -1.315 0 -2.38 1.066 -2.38 2.38 v 34.564 c 0 1.315 1.066 2.38 2.38 2.38 h 6.313 v 11.781 l 12.004 -11.781 h 33.012 c 1.315 0 2.38 -1.066 2.38 -2.38 V 35.369 C 55.917 34.054 54.852 32.988 53.537 32.988 z M 24.025 62.358 l -7.818 -10.164 l 2.354 -1.809 l 5.777 7.51 l 16.137 -15.822 l 2.079 2.121 L 24.025 62.358 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round" />
