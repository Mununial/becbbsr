    <section class="mission-section">
        <div class="pd_top_30"></div>
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <div class="mission-div">
                                                <div class="img">
                            <img data-src="https://sctevt.odisha.gov.in/public/assets/sctevthome/images/mission-image.jpg" alt=""
                                class="img-fluid" />
                            <h4>Our Mission</h4>
                            <div class="circle">
                                <img data-src="https://sctevt.odisha.gov.in/public/assets/sctevthome/images/mission-sm-img.png" alt="" />
                            </div>
                        </div>
                        <div class="content-div text-center">
                            <p>To spread the message of our mission &quot;Skilled-In-Odisha&quot; to every corner of the society and infuse a sense of social responsibility in the next generation.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mission-div">
                                                <div class="img">
                            <img data-src="https://sctevt.odisha.gov.in/public/assets/sctevthome/images/vision-image.jpg" alt=""
                                class="img-fluid" />
                            <h4>Our Vision</h4>
                            <div class="circle">
                                <img data-src="https://sctevt.odisha.gov.in/public/assets/sctevthome/images/vision-sm-img.png" alt="" />
                            </div>
                        </div>
                        <div class="content-div text-center">
                            <p>To ensure co-ordinated development of technical education and vocational training in the State with special emphasis on empowerment of woman and the weaker section of the society through productive partnership between industry and institute.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="pd_top_30"></div>
    </section>

