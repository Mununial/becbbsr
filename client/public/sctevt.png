              } else {
                console.log(response);
                if(response[0].type==4){
                  var QuestionLabelName='SDI-B has tied up with the following industries for setting up Center of Excellence in various fields';
                }else if(response[0].subcat && response[0].subcat.length>=1){
                  var QuestionLabelName='Please select the subject that interests you.';
                }else{
                  var QuestionLabelName='Please select the subject that interests you.';
                }
                data += '<div class="chat-log-entry clearlogdata"><div class="chat-entry-bot"><div class="chat-entry-bot-container"><div class="chat-entry-bot-profile-column"><div class="chat-entry-bot-profile"><i class="chat-avatar"></i></div></div><div class="chat-entry-bot-align"><div class="chat-entry-bot-wrap"><div class="chat-entry-bot-content"><div class="chat-entry-bot-main"><div class="chat-entry-bot-author">Message from Bot.</div><div class="chat-entry-bot-caption"><div class="chat-entry-bot-message-body">'+QuestionLabelName+'</div></div></div><div class="chat-entry-bot-persistent"><div class="chat-choices">';
                for (var i = 0;  i < response.length; i++) {
                  var type = "'"+response[i].request_type+"'";
                  var GetName = "'"+response[i].enquiry_question+"'";
                  var GetId = "'"+response[i].id+"'";
                  var resultType = "'"+response[i].type+"'";
                  if (i > 4) {
                    if (i ==5) {
                      data += '<button onclick="showQestion();" class="chat-choices-button add-class-remove" style="border-bottom: 1px solid #dfdfdf;"><b>Readmore</b></button>';
                    }
                    data += '<button onclick="getReturnValue('+escapeHtml(GetName)+','+GetId+','+type+','+resultType+');" value="'+response[i].enquiry_question+'" class="chat-choices-button remove-class" style="display:none;">'+response[i].enquiry_question+'</button>';
                  } else {
                    data += '<button onclick="getReturnValue('+escapeHtml(GetName)+','+GetId+','+type+','+resultType+');" value="'+response[i].enquiry_question+'" class="chat-choices-button">'+response[i].enquiry_question+'</button>';
                  }
                }
                data += '</div></div></div></div></div></div>';
                 $(".chat-buttons-button").click(function(){
                  $(".chat-buttons-button").removeClass('active');
                  $(this).addClass('active');
                })
              }
              var undefined = "'undefined'";
              var type = "'category'";
              var GetName = "'category'";
              var resultType = "'1'";
              data += subcatBtns;
              data += '<div class="chat-buttons backmenubtn"><button class="chat-buttons-button" onclick="getReturnValue('+escapeHtml(GetName)+','+undefined+','+type+','+resultType+')"><span class="chat-buttons-button-text" >Back To Menu</span></button><button class="chat-buttons-button" onclick="clearchatbox()"><span class="chat-buttons-button-text" >Reset Chat</span></button></div></div></div>';
              $(data).appendTo('#messages');
              $('#messages').stop().animate({
                scrollTop: $('#messages')[0].scrollHeight
              }, 800);
              var carLmt = 180;
              var readMoreTxt = " ... Read More";
              var readLessTxt = " Read Less";
              $("#addReadMore"+counter).each(function() {
                if ($(this).find(".firstSec").length)
                  return;
                var allstr = $(this).text();
                if (allstr.length > carLmt) {
                  var firstSet = allstr.substring(0, carLmt);
                  var secdHalf = allstr.substring(carLmt, allstr.length);
                  var strtoadd = firstSet + "<span class='SecSec' id='SecSec" + counter + "'>" + secdHalf + "</span><span onclick='showcontent(" + counter + ",1);' class='readMore' id='readMore" + counter + "'  title='Click to Show More'>" + readMoreTxt + "</span><span class='readLess' title='Click to Show Less' id='readLess" + counter + "' onclick='showcontent(" + counter + ",0);'>" + readLessTxt + "</span>";
                  $(this).html(strtoadd);
                }
              });
              // You will get response from your PHP page (what you echo or print)
               $(".chat-buttons-button").click(function(){
                $(".chat-buttons-button").removeClass('active');
                $(this).addClass('active');
              })
            },
            error: function(jqXHR, textStatus, errorThrown) {
              //alert(textStatus);
              console.log(textStatus, errorThrown);
            }
          });
        }
        //$('#'+replace_id+sl).append(data);
      }

      $('.chat-overlay').click(function() {
        //$('body').find('.chat-position').toggle();
        //$(this).hide();
        $(this).next().toggleClass("show-close");
        $('body').removeClass('chat-show');
      });
      $('.chat-button button').click(function() {
        $(this).parent().toggleClass("show-close");
        //$(this).parent().next('.chat-position').toggle();
        //$(this).parent().prev('.chat-overlay').toggle();
        $('body').toggleClass('chat-show');
      });
      $('.close-chat').click(function() {
        $(this).parent().closest('.chat-position').prev().toggleClass("show-close");
        //$(this).parent().closest('.chat-position').hide();
        //$('body').find('.chat-overlay').hide();
        $('body').toggleClass('chat-show');
      });


      function AddReadMore(counter)
      {
        var carLmt = 180;
        var readMoreTxt = " ... Read More";
        var readLessTxt = " Read Less";
        $("#addReadMore"+counter).each(function() {
          if ($(this).find(".firstSec").length)
            return;
          var allstr = $(this).text();
          if (allstr.length > carLmt) {
            var firstSet = allstr.substring(0, carLmt);
            var secdHalf = allstr.substring(carLmt, allstr.length);
            var strtoadd = firstSet + "<span class='SecSec' id='SecSec" + counter + "'>" + secdHalf + "</span><span onclick='showcontent(" + counter + ",1);' class='readMore' id='readMore" + counter + "'  title='Click to Show More'>" + readMoreTxt + "</span><span class='readLess' title='Click to Show Less' id='readLess" + counter + "' onclick='showcontent(" + counter + ",0);'>" + readLessTxt + "</span>";
            $(this).html(strtoadd);
          }
        });
      }
      function showcontent(counter, type)
      {
        if (type == 1) {
          $('#readMore'+counter).hide();
          $('#readLess'+counter).show();
          $('#SecSec'+counter).show();
        } else {
          $('#readMore'+counter).show();
          $('#readLess'+counter).hide();
          $('#SecSec'+counter).hide();
        }
        $('#messages').stop().animate({
          scrollTop: $('#messages')[0].scrollHeight
        }, 800);
      }
      AddReadMore(0,1);
      $(document).ready(function(){
        setTimeout(function() {
          $.ajaxSetup({
            headers: {
              'X-CSRF-TOKEN': $('input[name="csrf-token"]').attr('value')
            }
          });
          }, 2000);
          });

    $(document).ready(function () {
         $('#incfont').click(function () {
          // debugger;
             curSize = parseInt($('.theme-creote, p, span, a').css('font-size')) + 2;
             if (curSize <= 24)
                $('.theme-creote, p, span, a').css('font-size', curSize);
         });
         $('#decfont').click(function () {
             curSize = parseInt($('.theme-creote, p, span, a').css('font-size')) - 2;
             if (curSize >= 10)
                $('.theme-creote, p, span, a').css('font-size', curSize);
         });
         $('#resetfont').click(function () {
             $('.theme-creote, p, span, a').css('font-size', '');
         });


       //   Theme Color changer
       let themeChange = window.localStorage.getItem("themeChange");
          if(themeChange){
             $(".theme-creote").addClass('theme-black');
          }
          $(".theme-ch2").click(function(){
             $(".theme-creote").addClass('theme-black');
             window.localStorage.setItem("themeChange", true);
          });
          $(".theme-ch").click(function(){
             $(".theme-creote").removeClass('theme-black');
             window.localStorage.removeItem("themeChange");
          });
          $('.query-field-input').keypress(function (e) {
	         var key = e.which;
	         if(key == 13)  // the enter key code
	          {
	            getReturn();
	            return false;  
	          }
	      }); 
    });
    function escapeHtml(text) {
            var div = document.createElement('div');
            div.appendChild(document.createTextNode(text));
            return div.innerHTML;
        }
     function clearchatbox(){
          $(".chat-log-entry.clearlogdata").remove();
        }
</script>
<script type="text/javascript">
  $('img[data-src]').attr('src','https://sctevt.odisha.gov.in/public/assets/sctevthome/images/icon_contentload.gif');
</script>
<!-------------Chatbot Js End------->
</body>
</html>
