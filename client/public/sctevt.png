<script type="text/javascript">
   jQuery(function () {
       jQuery(".ext-class").click(function () {
           return confirm("This link shall take you to a page outside the website URL. For any query regarding the contents of linked page, please contact the webmaster of the concerned website.");
       });
   });

   $(document).ready(function () {
      $('#incfont').click(function () {
         curSize = parseInt($('.theme-creote, p, span, a').css('font-size')) + 2;
         if (curSize <= 18)
            $('.theme-creote, p, span, a').css('font-size', curSize);
      });
      $('#decfont').click(function () {
         curSize = parseInt($('.theme-creote, p, span, a').css('font-size')) - 2;
         if (curSize >= 10)
            $('.theme-creote, p, span, a').css('font-size', curSize);
      });
      $('#resetfont').click(function () {
         $('.theme-creote, p, span, a').removeAttr("style");
      });
   });

   $(document).ready(function(){
      let themeChange = window.localStorage.getItem("themeChange");
      if(themeChange){
         $(".theme-creote").addClass('theme-black');
      }
      $(".theme-ch2").click(function(){
         $(".theme-creote").addClass('theme-black');
         window.localStorage.setItem("themeChange", true);
      });
      $(".theme-ch").click(function(){
         $(".theme-creote").removeClass('theme-black');
         window.localStorage.removeItem("themeChange");
      });
   });

   $(document).ready(function() { 
      const modal = new bootstrap.Modal('#onload');
      // alert(sessionStorage.getItem("modalClosed"));
      // Check if modal has been closed for this session
      if (!sessionStorage.getItem("modalClosed")) {
         modal.show();
      }
      // When the modal is hidden, set session storage flag
      $('#onload').on('hidden.bs.modal', function () {
         sessionStorage.setItem("modalClosed", "true");
      });
      // Optionally, add an event listener for the close button
      $(".btn-close").click(function() {
         modal.hide();
         sessionStorage.setItem("modalClosed", "true");
      });
   });

   new WOW().init();
</script>   </div>

