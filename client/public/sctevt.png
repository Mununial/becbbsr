  <div class="chat-position">
    <div class="chat-box">
      <div class="chat-box-header">
        <strong class="chat-header-caption">Virtual Assistant</strong>
        <a href="javascript:void(0);" class="close-chat">&times;</a></div>
      <div class="chat-conversation">
        <div class="chat-ui">
          <div class="chat-ui-content">
            <div class="chat-log">
              <div class="conversation-log-scrollable scrollable"  id="messages">
                <div class="chat-log-entry">
                  <div class="chat-entry-bot">
                    <div class="chat-entry-bot-container">
                      <div class="chat-entry-bot-profile-column">
                        <div class="chat-entry-bot-profile">
                          <i class="chat-avatar"></i>
                        </div>
                      </div>
                      <div class="chat-entry-bot-align">
                        <div class="chat-entry-bot-wrap">
                          <div class="chat-entry-bot-content">
                            <div class="chat-entry-bot-main">
                              <div class="chat-entry-bot-author">Message from Bot.</div>
                              <div class="chat-entry-bot-message">
                                <div class="chat-entry-bot-message-body addReadMore showlesscontent">
                                 <!--  Welcome to CENTRAL PLACEMENT CELL, DTE&amp;T, ODISHA, Our virtual assistant can help in the following topics. -->
                                 Welcome to the State Council for Technical Education and Vocational Training. How can I assist you in the following categories?
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="chat-buttons">
                      <button class="chat-buttons-button active"  onclick="getReturnValue(&#039;Parent&#039;,50,'category',0);"><span class="chat-buttons-button-text" value="Parent">Parent</span></button><button class="chat-buttons-button"  onclick="getReturnValue(&#039;Placement Agencies&#039;,51,'category',0);"><span class="chat-buttons-button-text" value="Placement Agencies">Placement Agencies</span></button><button class="chat-buttons-button"  onclick="getReturnValue(&#039;Students&#039;,48,'category',0);"><span class="chat-buttons-button-text" value="Students">Students</span></button>                    </div>
                  </div>
                </div>
                <div class="chat-log-entry">
                  <div class="chat-entry-bot">
                    <div class="chat-entry-bot-container">
                      <div class="chat-entry-bot-profile-column">
                        <div class="chat-entry-bot-profile">
                          <i class="chat-avatar"></i>
                        </div>
                      </div>
                      <div class="chat-entry-bot-align">
                        <div class="chat-entry-bot-wrap">
                          <div class="chat-entry-bot-content">
                                                      </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="chat-ui-query-field">
            <div class="query-field query-field--has-menu">
              <div class="query-field-inner">
                <div class="query-field-align">
                  <div class="query-field-relative">
                    <button class="query-field-menu-opener"></button>
                    <input nr="" class="query-field-input" autocomplete="off" type="text" aria-label="Type your question here. Press Enter to search." placeholder="Type your question here" name="search_field" id="search_field" maxlength="100">
                  </div>
                </div>
                <div class="query-field-buttons">
                  <div class="query-field-custom-buttons"></div>
                  <button class="query-field-button" onclick="getReturn();">
                    <i class="query-field-icon"></i>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
