$(function() {
  $("img").lazy({
      attribute: "data-src",
      effect: "fadeIn", // Adds a fade-in effect when images load
      effectTime: 400,  // Time in milliseconds for the fade-in effect
      threshold: 200,   // Number of pixels to load images before they enter the viewport
      visibleOnly: true // Ensures images load only when visible in the viewport
  });
});



$('form input[type="text"], input[type="search"]').on('input', function() {
        //this reg exp prevent some potential XSS attacks by removing any characters that are not in the specified whitelist
        
      //  var inputPattern = /^[\u0900-\u097F\u0B00-\u0B7Fa-zA-Z0-9\s@.,_-]*$/;
      var inputPattern = /^[\u0900-\u097F\u0B00-\u0B7Fa-zA-Z0-9\s@.,_:-]*$/;

        var inputValue = $(this).val();
        if (!inputPattern.test(inputValue)) {
            return $(this).val(inputValue.replace(/[^\u0900-\u097F\u0B00-\u0B7Fa-zA-Z0-9@&#_,.\s/-]/g, ''));
        }

        // to prevent input starting with negative sign
        if (inputValue.startsWith('-')) {
            return $(this).val(inputValue.replace(/^-/, ''));
        }

        // Limit text input to 256 characters
        let inputTypes = ['text','search','email'];
        let inputType = $(this).attr('type');
        if( inputType == 'text' || inputType == 'search' || inputType == 'email') {
            if(inputValue.length > 256) {
                  return $(this).val(inputValue.substring(0, 256));
            }
        }

        // let totalWords = inputValue.split(/\s+/);
        // if ($(this).is('textarea') && totalWords.length > 500) { 
        //     let trimmedInput = totalWords.slice(0, 500).join(' ');
        //     return $(this).val(trimmedInput);
        // }
        return inputValue;
    });

 </script>
 
<!-------------Chatbot js----------->
<script type="text/javascript">
  var counter = 0;
  function getReturn()
      {
        if ($('#search_field').val()) {
          $('<div class="toremove"><img src="https://sctevt.odisha.gov.in/public/assets/sctevthome/images/chat/chat.gif" alt="" style="width: 10%;margin-left: 15px;"></div>').appendTo('#messages');
          $('#messages').stop().animate({
            scrollTop: $('#messages')[0].scrollHeight
          }, 800);
          var replace_value = $('#search_field').val();
          var rel_val = "'"+replace_value+"'";
          var data = '<div class="chat-log-entry clearlogdata"><div class="chat-entry-user"><div class="chat-entry-user-wrap"><div class="chat-entry-user-profile-column"><div class="chat-entry-user-profile"><i class="chat-avatar chat-avatar--user"></i></div></div><div class="chat-entry-user-align"><div class="chat-entry-user-author">Message from Visitor.</div><div class="chat-entry-user-message">'+replace_value+'</div></div></div></div></div>';
          //var data = '<div class="message from" style="background-color: #f4590d;">'+replace_value+'</div><div style="clear:both;"></div>';

          $.ajax({
            url: "https://sctevt.odisha.gov.in/chat-enquiry",
            type: 'POST',
            dataType: "json",
            data: {"request_type": 'all', "request_name": replace_value, "resultType": 0, "_token" : pagetoken},
            success: function (response) {
              counter++;
              $('.toremove').remove();
              $('#search_field').val('');
              if (response[0].type == 3) {
                data += '<div class="chat-log-entry clearlogdata"><div class="chat-entry-bot"><div class="chat-entry-bot-container"><div class="chat-entry-bot-profile-column"><div class="chat-entry-bot-profile"><i class="chat-avatar"></i></div></div><div class="chat-entry-bot-align"><div class="chat-entry-bot-wrap"><div class="chat-entry-bot-content"><div class="chat-entry-bot-main"><div class="chat-entry-bot-author">Message from Bot.</div><div class="chat-entry-bot-message">';
                for (var i = 0;  i < response.length; i++) {
                  if (response[i].enquiry_question.length > 180) {
                    data += '<div class="chat-entry-bot-message-body addReadMore showlesscontent"  id="addReadMore' + counter + '">'+response[i].enquiry_question+'</div>';
                  } else {
                    data += '<div class="chat-entry-bot-message-body">'+response[i].enquiry_question+'</div>';
                  }
                }
                data += '</div></div></div></div></div></div>';
              } else {
                //alert(2)
                data += '<div class="chat-log-entry clearlogdata"><div class="chat-entry-bot"><div class="chat-entry-bot-container"><div class="chat-entry-bot-profile-column"><div class="chat-entry-bot-profile"><i class="chat-avatar"></i></div></div><div class="chat-entry-bot-align"><div class="chat-entry-bot-wrap"><div class="chat-entry-bot-content"><div class="chat-entry-bot-main"><div class="chat-entry-bot-author">Message from Bot.</div><div class="chat-entry-bot-caption"><div class="chat-entry-bot-message-body">Questions Searched on "'+replace_value+'"</div></div></div><div class="chat-entry-bot-persistent"><div class="chat-choices">';
                for (var i = 0;  i < response.length; i++) {
                  if(!response[i].subcat){
                    var type = "'"+response[i].request_type+"'";
                    var GetName = "'"+response[i].enquiry_question+"'";
                    var GetId = "'"+response[i].id+"'";
                    var resultType = "'"+response[i].type+"'";
                    if (i > 4) {
                      if (i ==5) {
                        data += '<button onclick="showQestion();" class="chat-choices-button add-class-remove" style="border-bottom: 1px solid #dfdfdf;">Readmore</button>';
                      }
                      data += '<button onclick="getReturnValue('+escapeHtml(GetName)+','+GetId+','+type+','+resultType+');" value="'+response[i].enquiry_question+'" class="chat-choices-button remove-class" style="display:none;">'+response[i].enquiry_question+'</button>';
                    } else {
                      data += '<button onclick="getReturnValue('+escapeHtml(GetName)+','+GetId+','+type+','+resultType+');" value="'+response[i].enquiry_question+'" class="chat-choices-button">'+response[i].enquiry_question+'</button>';
                    }
                  }else{
                     let subcatBtns = '';
                      if(response[i].subcat){
                        let subcat = response[i].subcat;
                        if(response[i].enquiry_question!=''){
                          subcatBtns += '<button onclick="javascript:void(0)" value="'+response[i].enquiry_question+'" class="chat-choices-button">'+response[i].enquiry_question+'</button>';
                        }
                        subcatBtns += '<div class="chat-buttons">';
                        for(let i=0; i<subcat.length;i++){
                          subcatBtns += '<button class="chat-buttons-button" onclick="getReturnValue(\''+escapeHtml(subcat[i].name)+'\','+subcat[i].id+',\'category\',0);"> <span class="chat-buttons-button-text" value="'+subcat[i].name+'">'+subcat[i].name+'</span></button>';
                        }
                        subcatBtns += ' </div>';
                        data += subcatBtns;
                      }
                  }

                }
                data += '</div></div></div></div></div></div>';
              }
              var undefined = "'undefined'";
              var type = "'category'";
              var GetName = "'category'";
              var resultType = "'1'";
              data += '<div class="chat-buttons backmenubtn"><button class="chat-buttons-button" onclick="getReturnValue('+escapeHtml(GetName)+','+undefined+','+type+','+resultType+')"><span class="chat-buttons-button-text" >Back To Menu</span></button><button class="chat-buttons-button" onclick="clearchatbox()"><span class="chat-buttons-button-text" >Reset Chat</span></button></div></div></div>';
              $(data).appendTo('#messages');
              $('#messages').stop().animate({
                scrollTop: $('#messages')[0].scrollHeight
              }, 800);
              var carLmt = 180;
              var readMoreTxt = " ... Read More";
              var readLessTxt = " Read Less";
              $("#addReadMore"+counter).each(function() {
                if ($(this).find(".firstSec").length)
                  return;
                var allstr = $(this).text();
                if (allstr.length > carLmt) {
                  var firstSet = allstr.substring(0, carLmt);
                  var secdHalf = allstr.substring(carLmt, allstr.length);
                  var strtoadd = firstSet + "<span class='SecSec' id='SecSec" + counter + "'>" + secdHalf + "</span><span onclick='showcontent(" + counter + ",1);' class='readMore' id='readMore" + counter + "'  title='Click to Show More'>" + readMoreTxt + "</span><span class='readLess' title='Click to Show Less' id='readLess" + counter + "' onclick='showcontent(" + counter + ",0);'>" + readLessTxt + "</span>";
                  $(this).html(strtoadd);
                }
              });
              // You will get response from your PHP page (what you echo or print)
            },
            error: function(jqXHR, textStatus, errorThrown) {
              //alert(textStatus);
              console.log(textStatus, errorThrown);
            }
          });
        }
      }
      function showQestion()
      {
        $('.add-class-remove').hide();
        $('.remove-class').show();
        $('#messages').stop().animate({
          scrollTop: $('#messages')[0].scrollHeight
        }, 800);
      }
      $(".chat-buttons-button").click(function(){
        $(".chat-buttons-button").removeClass('active');
        $(this).addClass('active');
      })
      function getReturnValue(replace_value, ajax_id, type, resultType)
      {

        $(".backmenubtn").remove();

        $('<div class="toremove"><img src="https://sctevt.odisha.gov.in/public/assets/sctevthome/images/chat/chat.gif" alt="" style="width: 10%;margin-left: 15px;"></div>').appendTo('#messages');
        $('#messages').stop().animate({
          scrollTop: $('#messages')[0].scrollHeight
        }, 800);
        if (ajax_id == 'undefined') {
          var data = '<div class="chat-log-entry clearlogdata"><div class="chat-entry-bot"><div class="chat-entry-bot-container"><div class="chat-entry-bot-profile-column"><div class="chat-entry-bot-profile"><i class="chat-avatar"></i></div></div><div class="chat-entry-bot-align"><div class="chat-entry-bot-wrap"><div class="chat-entry-bot-content"><div class="chat-entry-bot-main"><div class="chat-entry-bot-author">Message from Bot.</div><div class="chat-entry-bot-message"><div class="chat-entry-bot-message-body addReadMore showlesscontent">Welcome To SCTEVT, How Can I Help For Following Category</div></div></div></div></div></div></div><div class="chat-buttons">';
          //alert(2)
          $.ajax({
            url: "https://sctevt.odisha.gov.in/chat-category",
            type: 'POST',
            dataType: "json",
            data: {"status": 1, "_token" : pagetoken},
            success: function (response) {
             
              counter++;
              $('.toremove').remove();

              let subcatBtns = '';
              if(response[0].subcat){
                let subcat = response[0].subcat;
                subcatBtns = '<div class="chat-buttons">';
                for(let i=0; i<subcat.length;i++){
                  subcatBtns += '<button class="chat-buttons-button" onclick="getReturnValue(\''+subcat[i].name+'\','+subcat[i].id+',\'category\',0);"> <span class="chat-buttons-button-text" value="'+subcat[i].name+'">'+subcat[i].name+'</span></button>';
                }
                subcatBtns += ' </div>';
              }

              for (var i = 0;  i < response.length; i++) {
                var type = "'category'";
                var GetName = "'"+response[i].cat_name+"'";
                var GetId = "'"+response[i].id+"'";
                var resultType = "'0'";
                data += '<button class="chat-buttons-button"  onclick="getReturnValue('+GetName+','+GetId+','+type+','+resultType+');"><span class="chat-buttons-button-text"  value="'+response[i]['cat_name']+'">'+response[i]['cat_name']+'</span></button>';
              }
              data += '</div></div></div>';
              $(data).appendTo('#messages');
              $('#messages').stop().animate({
                scrollTop: $('#messages')[0].scrollHeight
              }, 800);

              var carLmt = 180;
              var readMoreTxt = " ... Read More";
              var readLessTxt = " Read Less";
              $("#addReadMore"+counter).each(function() {
                if ($(this).find(".firstSec").length)
                  return;
                var allstr = $(this).text();
                if (allstr.length > carLmt) {
                  var firstSet = allstr.substring(0, carLmt);
                  var secdHalf = allstr.substring(carLmt, allstr.length);
                  var strtoadd = firstSet + "<span class='SecSec' id='SecSec" + counter + "'>" + secdHalf + "</span><span onclick='showcontent(" + counter + ",1);' class='readMore' id='readMore" + counter + "'  title='Click to Show More'>" + readMoreTxt + "</span><span class='readLess' title='Click to Show Less' id='readLess" + counter + "' onclick='showcontent(" + counter + ",0);'>" + readLessTxt + "</span>";
                  $(this).html(strtoadd);
                }
              });
              // You will get response from your PHP page (what you echo or print)
               $(".chat-buttons-button").click(function(){
                $(".chat-buttons-button").removeClass('active');
                $(this).addClass('active');
              })
            },
            error: function(jqXHR, textStatus, errorThrown) {
              //alert(textStatus);
              console.log(textStatus, errorThrown);
            }
          });
        } else {
          var rel_val = "'"+replace_value+"'";
          var data = '<div class="chat-log-entry clearlogdata"><div class="chat-entry-user"><div class="chat-entry-user-wrap"><div class="chat-entry-user-profile-column"><div class="chat-entry-user-profile"><i class="chat-avatar chat-avatar--user"></i></div></div><div class="chat-entry-user-align"><div class="chat-entry-user-author">Message from Visitor.</div><div class="chat-entry-user-message">'+replace_value+'</div></div></div></div></div>';
          //var data = '<div class="message from" style="background-color: #f4590d;">'+replace_value+'</div><div style="clear:both;"></div>';
         // alert(3)
          $.ajax({
            url: "https://sctevt.odisha.gov.in/chat-enquiry",
            type: 'POST',
            dataType: "json",
            data: {"request_type": type, "request_id": ajax_id, "resultType": resultType, "_token" : pagetoken},
            success: function (response) {

              counter++;
              $('.toremove').remove();
              let subcatBtns = '';
              if(response[0].subcat){
                let subcat = response[0].subcat;
                subcatBtns = '<div class="chat-buttons">';
                for(let i=0; i<subcat.length;i++){
                  subcatBtns += '<button class="chat-buttons-button" onclick="getReturnValue(\''+subcat[i].name+'\','+subcat[i].id+',\'category\',0);"> <span class="chat-buttons-button-text" value="'+subcat[i].name+'">'+subcat[i].name+'</span></button>';
                }
                subcatBtns += ' </div>';
              }
              if (response[0].type == 3) {


                data += '<div class="chat-log-entry clearlogdata"><div class="chat-entry-bot"><div class="chat-entry-bot-container"><div class="chat-entry-bot-profile-column"><div class="chat-entry-bot-profile"><i class="chat-avatar"></i></div></div><div class="chat-entry-bot-align"><div class="chat-entry-bot-wrap"><div class="chat-entry-bot-content"><div class="chat-entry-bot-main"><div class="chat-entry-bot-author">Message from Bot.</div><div class="chat-entry-bot-message">';
                if(response[0].subTitle){
                  data +=response[0].subTitle;
                }
                for (var i = 0;  i < response.length; i++) {
                  if(!response[i].dynamicpage){
                    if (response[i].enquiry_question.length > 180) {
                      data += '<div class="chat-entry-bot-message-body addReadMore showlesscontent"  id="addReadMore' + counter + '">'+response[i].enquiry_question+'</div>';
                    } else {
                      data += '<div class="chat-entry-bot-message-body">'+response[i].enquiry_question+'</div>';
