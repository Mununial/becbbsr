            padding: 15px 0;
            height: 200px;
        }

        .grey-box {
            padding: 15px;
            box-shadow: 1px 1px 10px #3335;
            height: 92%;
        }

        .price_plan_box.style_one .top h5 {
            font-size: 14px;
            font-weight: 600;
            margin: -35px -35px 10px;
            background: var(--primary-color-one);
            color: #fff;
            padding: 12px 15px 10px;
            border-radius: 10px 10px 0 0;
            text-transform: uppercase;
            text-align: center;
            line-height: 1;
        }

        #notification .title {
            border-bottom: 2px solid;
            padding: 0;
            width: 275px;
            margin: 0 auto 15px;
        }
        .slick-slide-single {
            padding: 10px;
        }
        .slick-arrow {
            position: absolute;
            top: calc(50% - 20px);
            width: 40px;
            line-height: 40px;
            text-align: center;
            z-index: 10;
            background: #fff;
            font-size: 30px;
            border-radius: 50%;
            box-shadow: 1px 1px 15px #3333;
            opacity: 0;
            pointer-events: none;
            transition: all 0.3s;
        }
        .slick-slider .slick-arrow.left{left: 0; }
        .slick-slider .slick-arrow.right{right: 0;}

        .slick-slider:hover .slick-arrow.left{
            opacity: 1;
            pointer-events: all;
            left: -34px;
        }
        .slick-slider:hover .slick-arrow.right{
            opacity: 1;
            pointer-events: all;
            right: -34px;
        }
    </style>
